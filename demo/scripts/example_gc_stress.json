{
  "name": "GC压力测试",
  "description": "全盘写满 -> 反复覆写 -> 触发GC -> 验证空间可用\nLBA范围: 1-180",
  "steps": [
    { "type": "sequential", "count": 180, "desc": "阶段1: 填满全盘(180页)" },
    { "type": "overwrite", "lba": 1, "count": 20, "desc": "阶段2: 覆写LBA 1共20次" },
    { "type": "overwrite", "lba": 50, "count": 20, "desc": "阶段2: 覆写LBA 50共20次" },
    { "type": "overwrite", "lba": 100, "count": 20, "desc": "阶段2: 覆写LBA 100共20次" },
    { "type": "overwrite", "lba": 150, "count": 20, "desc": "阶段2: 覆写LBA 150共20次" },
    { "type": "sequential", "count": 36, "desc": "阶段3: 写入36页(应触发GC)" },
    { "type": "assert_gc_count", "op": ">=", "value": 1, "desc": "断言: GC至少触发1次" },
    { "type": "sequential", "count": 36, "desc": "阶段4: GC后继续写入36页验证空间" }
  ]
}
